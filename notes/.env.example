# Top-level compose env. Copy to notes/.env on the VPS and fill in.
# notes/api/.env carries the api-specific secrets; this file is for compose
# interpolation and Caddy/Garage values shared across services.

# Tailscale identity for Caddy. Run `tailscale status --self --json | jq -r .Self.HostName` on the VPS.
TAILNET_HOSTNAME=notes
TAILNET_DOMAIN=tail-XXXXX.ts.net
TAILSCALE_IP=100.65.47.66

# Garage cluster secrets. Generate with `openssl rand -hex 32`.
GARAGE_RPC_SECRET=replace-with-32-bytes-hex
GARAGE_ADMIN_TOKEN=replace-with-base64
GARAGE_METRICS_TOKEN=replace-with-base64

# Comma-separated Tailscale logins allowed into the admin app. Used once admin lands.
NOTES_ADMIN_ALLOWED_USERS=
