# notes-api process env. Copy to .env on the VPS and fill in. Never commit .env.
# DATABASE_URL is set by docker-compose; not needed here.

# Bearer token for /api/v1/sync/* — generate with `openssl rand -hex 32`.
NOTES_API_SYNC_TOKEN=replace-me-with-random-32-bytes-hex

# Garage S3 credentials, populated by `notes/scripts/bootstrap-garage.sh`.
GARAGE_ACCESS_KEY=replace-after-bootstrap
GARAGE_SECRET_KEY=replace-after-bootstrap

# Optional overrides. Defaults shown.
# NOTES_API_MAX_ATTACH_MB=25
# PG_MAX_CONNECTIONS=10
# PORT=3000
# RUST_LOG=info,sqlx=warn
